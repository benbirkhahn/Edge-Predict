PORT=3000

ODDS_PROVIDER=consensus
SHARP_API_KEY=
SHARP_API_BOOKS=draftkings,fanduel
SHARP_API_LEAGUES=mlb,nba,nhl
ODDS_REFRESH_SECONDS=120
CONSENSUS_SCORE_ONLY=true
DEFAULT_MIN_MAPPING_CONFIDENCE=0.85

# demo or prod. Start with demo.
KALSHI_ENV=demo

# Kalshi API key ID.
KALSHI_API_KEY=

# RSA private key. Use escaped newlines if keeping it on one line.
KALSHI_API_SECRET=

# Server-side hard gate for live orders. Keep false until demo testing passes.
KALSHI_LIVE_TRADING_ENABLED=false

DEFAULT_MAX_STAKE_DOLLARS=1
DEFAULT_DAILY_LOSS_LIMIT_DOLLARS=10
DEFAULT_MAX_OPEN_POSITIONS=3
DEFAULT_EXPOSURE_LIMIT_PERCENT=10
DEFAULT_MIN_EV_PERCENT=1.5
DEFAULT_MIN_CONFIDENCE_PERCENT=55
DEFAULT_MIN_LIQUIDITY_DOLLARS=12
DEFAULT_TIME_TO_CLOSE_MINUTES=60
DEFAULT_MAX_HOURS_AHEAD=36
DEFAULT_MARKET_COOLDOWN_MINUTES=120
DEFAULT_KELLY_FRACTION=0.1
DEFAULT_ALLOWED_TICKER_PREFIXES=KXMLB,KXNBA,KXNHL
